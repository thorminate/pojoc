{
  "comments": {
    "lineComment": { "comment": "//" }
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "folding": {
    "offSide": false,
    "markers": {
      "start": "^\\s*//\\s*#region\\b",
      "end": "^\\s*//\\s*#endregion\\b"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^.*(\\{[^}\"']*|\\([^\\)\"']*|\\[[^\\]\"']*)$",
    "decreaseIndentPattern": "^\\s*[\\}\\]\\)].*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*//.*$",
      "action": {
        "indent": "none",
        "appendText": "// "
      }
    }
  ]
}
