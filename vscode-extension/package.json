{
  "name": "pojoc-vscode",
  "displayName": "Pojoc",
  "description": "Language support for Pojoc schema files",
  "version": "0.5.0",
  "engines": {
    "vscode": "^1.85.0",
    "node": "^24.18.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "license": "MIT",
  "activationEvents": [],
  "repository": {
    "directory": "vscode-extension",
    "type": "git",
    "url": "https://github.com/thorminate/pojoc.git"
  },
  "packageManager": "pnpm@10.12.4",
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "pojoc",
        "aliases": [
          "Pojoc"
        ],
        "extensions": [
          ".pojoc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "pojoc",
        "scopeName": "source.pojoc",
        "path": "./syntaxes/pojoc.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Pojoc",
      "properties": {
        "pojoc.serverPath": {
          "type": "string",
          "default": "pojoc-lsp",
          "description": "Path to the pojoc-lsp executable"
        }
      }
    },
    "configurationDefaults": {
      "[pojoc]": {
        "editor.wordBasedSuggestions": "off"
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch"
  },
  "dependencies": {
    "vscode-languageclient": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "typescript": "^5.4.0"
  }
}
