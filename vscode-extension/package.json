{
  "name": "pojoc-vscode",
  "displayName": "Pojoc",
  "description": "Language support for Pojoc schema files",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "pojoc",
        "aliases": [
          "Pojoc"
        ],
        "extensions": [
          ".pojoc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "pojoc",
        "scopeName": "source.pojoc",
        "path": "./syntaxes/pojoc.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Pojoc",
      "properties": {
        "pojoc.serverPath": {
          "type": "string",
          "default": "pojoc-lsp",
          "description": "Path to the pojoc-lsp executable"
        }
      }
    },
    "configurationDefaults": {
      "[pojoc]": {
        "editor.wordBasedSuggestions": "off"
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^10.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^26.0.0",
    "typescript": "^5.4.0"
  }
}
