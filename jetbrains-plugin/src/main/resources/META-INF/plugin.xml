<idea-plugin>
    <id>net.thorminate.pojoc</id>
    <name>Pojoc</name>
    <vendor url="https://github.com/thorminate/pojoc">Thorminate</vendor>

    <description><![CDATA[
        Language support for <b>.pojoc</b> schema files.<br/>
        Provides syntax highlighting (TextMate grammar) and full LSP support
        via the Pojoc language server (<code>pojoc lsp</code>).
    ]]></description>

    <depends>com.intellij.modules.lang</depends>
    <depends>com.redhat.devtools.lsp4ij</depends>
    <depends>org.jetbrains.plugins.textmate</depends>

    <extensions defaultExtensionNs="com.intellij">
        <textmate.bundleProvider
                implementation="net.thorminate.pojoc.PojocTextMateBundleProvider"/>
    </extensions>

    <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">
        <server
                id="pojocLanguageServer"
                name="Pojoc Language Server"
                factoryClass="net.thorminate.pojoc.PojocLanguageServerFactory">
            <description><![CDATA[
                Language server for Pojoc schema files (<code>*.pojoc</code>).
                Launched via <code>pojoc lsp --stdio</code>.
            ]]></description>
        </server>

        <fileNamePatternMapping
                patterns="*.pojoc"
                serverId="pojocLanguageServer"
                languageId="pojoc"/>
    </extensions>
</idea-plugin>