{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Pojoc",
  "scopeName": "source.pojoc",
  "fileTypes": ["pojoc"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#decl-extends" },
    { "include": "#decl-simple" },
    { "include": "#import-decl" },
    { "include": "#schema-decl" },
    { "include": "#version-decl" },
    { "include": "#diff-op" },
    { "include": "#arrow" },
    { "include": "#scope-resolution" },
    { "include": "#type-name-versioned" },
    { "include": "#field-decl" },
    { "include": "#booleans" },
    { "include": "#numbers" },
    { "include": "#types" },
    { "include": "#modifiers" },
    { "include": "#keywords" },
    { "include": "#type-name-bare" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.double-slash.pojoc",
      "match": "//.*$"
    },
    "strings": {
      "name": "string.quoted.double.pojoc",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.pojoc", "match": "\\\\." }
      ]
    },
    "decl-extends": {
      "comment": "type/enum/union/bitset Name extends Name@N — covers every extends header in the schema",
      "match": "\\b(type|enum|union|bitset)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+(extends)\\s+([A-Za-z_][A-Za-z0-9_]*)(@)([0-9]+)\\b",
      "captures": {
        "1": { "name": "keyword.control.pojoc" },
        "2": { "name": "entity.name.type.pojoc" },
        "3": { "name": "keyword.control.pojoc" },
        "4": { "name": "entity.name.type.pojoc" },
        "5": { "name": "punctuation.definition.version-pin.pojoc" },
        "6": { "name": "constant.numeric.version.pojoc" }
      }
    },
    "decl-simple": {
      "comment": "type/enum/union/bitset Name (no extends)",
      "match": "\\b(type|enum|union|bitset)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.control.pojoc" },
        "2": { "name": "entity.name.type.pojoc" }
      }
    },
    "import-decl": {
      "comment": "import \"path/to/file.pojoc\" as Alias",
      "match": "\\b(import)\\s+(\"(?:[^\"\\\\]|\\\\.)*\")\\s+(as)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.control.pojoc" },
        "2": { "patterns": [{ "include": "#strings" }] },
        "3": { "name": "keyword.control.pojoc" },
        "4": { "name": "entity.name.type.pojoc" }
      }
    },
    "schema-decl": {
      "match": "\\b(schema)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.control.pojoc" },
        "2": { "name": "entity.name.type.pojoc" }
      }
    },
    "version-decl": {
      "match": "\\b(version)\\s+([0-9]+)\\b",
      "captures": {
        "1": { "name": "keyword.control.pojoc" },
        "2": { "name": "constant.numeric.version.pojoc" }
      }
    },
    "diff-op": {
      "comment": "leading +/-/~ on a diff/enum-extend/bitset-extend line, e.g. `+ Heal: HealPayload`, `- u8_min`, `~ u8_max -> u8_to_i64: i64`",
      "match": "^\\s*([+~-])(?=\\s)",
      "captures": { "1": { "name": "keyword.operator.diff.pojoc" } }
    },
    "arrow": {
      "name": "keyword.operator.arrow.pojoc",
      "match": "->"
    },
    "scope-resolution": {
      "comment": "NumericBounds::MinU8 — enum value access",
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(::)([A-Za-z_][A-Za-z0-9_]*)\\b",
      "captures": {
        "1": { "name": "entity.name.type.pojoc" },
        "2": { "name": "punctuation.accessor.pojoc" },
        "3": { "name": "variable.other.enummember.pojoc" }
      }
    },
    "type-name-versioned": {
      "comment": "Name@N used as a type reference outside a decl header, e.g. inside `extends Payload@2`",
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(@)([0-9]+)\\b",
      "captures": {
        "1": { "name": "entity.name.type.pojoc" },
        "2": { "name": "punctuation.definition.version-pin.pojoc" },
        "3": { "name": "constant.numeric.version.pojoc" }
      }
    },
    "field-decl": {
      "comment": "snake_case field names before a colon. Lowercase-only so PascalCase union tags (Move:, Attack:) fall through to type-name-bare instead.",
      "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(:)(?!:)",
      "captures": {
        "1": { "name": "variable.other.member.pojoc" },
        "2": { "name": "punctuation.separator.key-value.pojoc" }
      }
    },
    "booleans": {
      "name": "constant.language.boolean.pojoc",
      "match": "\\b(true|false)\\b"
    },
    "numbers": {
      "name": "constant.numeric.pojoc",
      "match": "\\b-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?\\b"
    },
    "types": {
      "name": "support.type.pojoc",
      "match": "\\b(u8|u16|u32|u64|i8|i16|i32|i64|f32|f64|vfloat|bool|string|varint32|varint64|map)\\b"
    },
    "modifiers": {
      "name": "storage.modifier.pojoc",
      "match": "\\b(lazy|const|delta)\\b"
    },
    "keywords": {
      "name": "keyword.control.pojoc",
      "match": "\\b(fields|diff|extends|import)\\b"
    },
    "type-name-bare": {
      "comment": "fallback: any remaining PascalCase identifier is a type reference, union variant tag, or bitset-literal constructor name",
      "name": "entity.name.type.pojoc",
      "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
    },
    "operators": {
      "name": "keyword.operator.pojoc",
      "match": "(\\?|=)"
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.definition.block.begin.pojoc", "match": "\\{" },
        { "name": "punctuation.definition.block.end.pojoc", "match": "\\}" },
        { "name": "punctuation.definition.array.begin.pojoc", "match": "\\[" },
        { "name": "punctuation.definition.array.end.pojoc", "match": "\\]" },
        {
          "name": "punctuation.definition.parameters.begin.pojoc",
          "match": "\\("
        },
        {
          "name": "punctuation.definition.parameters.end.pojoc",
          "match": "\\)"
        },
        { "name": "punctuation.definition.generic.begin.pojoc", "match": "<" },
        { "name": "punctuation.definition.generic.end.pojoc", "match": ">" },
        { "name": "punctuation.separator.comma.pojoc", "match": "," },
        { "name": "punctuation.accessor.pojoc", "match": "::" },
        { "name": "punctuation.separator.colon.pojoc", "match": ":" },
        { "name": "punctuation.definition.version-pin.pojoc", "match": "@" }
      ]
    }
  }
}
