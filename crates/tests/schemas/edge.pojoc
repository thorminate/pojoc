schema Edge {
  import "player.pojoc" as Player

  version 1 {
    enum NumericBounds {
      MinU8,
      MaxU8,
      MinI64,
      MaxI64,
    }

    type NestedLeaf {
      leaf_val: string = "leaf"
      leaf_numeric: i32 = 42
      leaf_rotation: vfloat(min: 0, max: 360, step: 0.1) = 0.0
    }

    type MiddleLayer {
      leaf: NestedLeaf
      leaf_arr: [NestedLeaf] = []
      leaf_opt: NestedLeaf?
    }

    // Tagged-union payload types — simple, stable shapes so the union
    // machinery itself (discriminant + length prefix, Unknown fallback)
    // is what's under test, not the payload structs.
    type MovePayload {
      dx: i32 = 0
      dy: i32 = 0
    }

    type AttackPayload {
       target_id: u32 = 0
       damage: f32 = 0.0
       knockback: vfloat(min: 0, max: 50, step: 0.1) = 0
    }

    union Payload {
      Move: MovePayload,
      Attack: AttackPayload,
    }

    // Generic type templates — monomorphized per distinct instantiation, so
    // Box<i32> and Pair<i32, string> below become two entirely separate
    // generated structs sharing no code, exercising the generics feature.
    type Box<T> {
      value: T
    }

    type Pair<A, B> {
      first: A
      second: B
    }

    type Triple<A, B, C> {
      first: A
      second: B
      third: C
    }

    fields {
      // Primitive & Boundary Numerical Extremes
      u8_max: u8 = 255
      u8_min: u8 = 0
      i64_max: i64 = 9223372036854775807
      i64_min: i64 = -9223372036854775808
      varint32_max: varint32 = 2147483647
      varint64_min: varint64 = 0

      // Special IEEE 754 Floating-Point Const Injections
      f32_nan: f32 = 0.0
      f32_inf: f32 = 3.40282347e38
      f64_neg_inf: f64 = -1.7976931348623157e+308

      // Empty collections, Fixed-Size types, and Strings
      empty_str: string = ""
      spaces_str: string = "     "
      fixed_str_min: string(1) = "A"

      // Array Combinations
      empty_arr: [string] = []
      fixed_arr_empty: [i32](0) = []
      fixed_arr_populated: [u8](4) = [0, 0, 0, 0]
      tuple_array: [(f32, bool)] = []

      // Delta arrays
      delta_positions: [i32](delta) = []
      delta_i64_seq: [i64](delta) = []
      delta_u64_seq: [u64](delta) = [0, 18446744073709551615, 0]
      delta_u16_seq: [u16](delta) = [100, 105, 110, 90]
      delta_i8_seq: [i8](delta) = [-128, -1, 0, 127]
      delta_single: [u32](delta) = [42]

      delta_fixed_u8: [u8](delta, 4) = [10, 12, 11, 20]
      delta_fixed_empty: [i32](delta, 0) = []

      legacy_positions: [i32] = []

      // Deep Structured Objects
      root_struct: MiddleLayer

      // Generic instantiations — same template (Box<T>), different type
      // arguments, must produce distinct wire-compatible structs.
      generic_box: Box<i32>
      generic_pair: Pair<i32, string>
      generic_triple: Triple<i32, string, bool>

      // `as Alias` picks the monomorphized struct's name explicitly instead
      // of the auto-mangled one — same template and shape as `generic_box`,
      // but a distinct, separately-named type.
      generic_flag_box: Box<bool> as FlagBox

      // Lazy fields present from v1 — skipped on hot path, decoded on demand
      lazy_blob: lazy [u8] = []                    // raw byte payload, often unused
      lazy_leaf: lazy NestedLeaf                   // heavy nested struct, skip if not needed

      // Constant Primitive definitions
      pi_const: const f64 = 3.141592653589793
      flag_const: const bool = true

      // Native Enumerations
      bounds_enum: NumericBounds = NumericBounds::MinU8

      // Tagged unions — scalar, array, and optional union-typed fields
      action: Payload
      action_log: [Payload] = []
      pending_action: Payload?

      // Range-quantized floats — bit width derives from (max-min)/step
      angle_deg: vfloat(min: 0, max: 360, step: 0.1) = 0.0
      normalized: vfloat(min: -1.0, max: 1.0, step: 0.001) = 0.0

      // Exact byte-boundary cases: 256 steps fits 8 bits, 257 spills to 9
      vfloat_256_steps: vfloat(min: 0, max: 255, step: 1) = 0.0
      vfloat_257_steps: vfloat(min: 0, max: 256, step: 1) = 0.0

      vfloat_arr: [vfloat(min: 0, max: 360, step: 0.1)] = []
      fixed_vfloat_arr: [vfloat(min: 0, max: 255, step: 1)](4) = [0.0, 0.0, 0.0, 0.0]

      imported_player: Player@2
    }
  }

  version 2 {
    enum NumericBounds extends NumericBounds@1 {
      + ExtraVariant
      ~ MinU8 -> ResetZero
    }

    type MiddleLayer extends MiddleLayer@1 {
      + weight: f32 = 1.0
      + secondary_leaf: NestedLeaf?
    }

    type HealPayload {
      target_id: u32 = 0
      amount: f32 = 0.0
      overheal: bool = false
      splash_radius: vfloat(min: 0, max: 10, step: 0.1) = 0.0
    }

    // Same-name generic evolution — Box<T> gains a field the same way any
    // other struct type evolves via `extends`, just with its type parameter
    // carried through unchanged.
    type Box<T> extends Box<T>@1 {
      + label: string = "unlabeled"
    }

    // Add-only union evolution — same shape as the enum/bitset extension
    // mechanism, just for tagged variants instead of plain discriminants.
    union Payload extends Payload@1 {
      + Heal: HealPayload
    }

    diff {
      - u8_min
      ~ u8_max -> u8_to_i64: i64
      ~ i64_max -> i64_to_f32: f32
      ~ bounds_enum: NumericBounds
      ~ empty_str -> nullified_str: string?
      ~ fixed_str_min: string(8)
      + newly_added_optional: u64?
      ~ root_struct: MiddleLayer

      // Re-resolve to the v2 Box<i32> instantiation (now label-aware) — same
      // repin-via-UpdateType exercise as `root_struct` above, but for a
      // monomorphized generic type instead of a plain struct.
      ~ generic_box: Box<i32>
      ~ legacy_positions: [i32](delta)
      + delta_u32_seq: [u32](delta, 6) = [1000, 1000, 999, 1500, 1500, 1000]

      // Re-resolve to Payload@2 (now Heal-aware). The generated reader/writer
      // is name-keyed and identical regardless of which TypeId the field
      // carries, but this still walks the FieldMapping::Cast branch in
      // lineage/decode/encode for a union type — worth confirming it's a
      // clean no-op rather than a silent miscompile.
      ~ action: Payload

      // Lazy field added via diff — must be optional so v1 messages default to None
      + lazy_delta_log: lazy [i64](delta)?         // per-message event log, expensive to decode

      // Step narrowed 0.1 -> 0.05, same range — bit width grows, old wire data must still decode
      ~ angle_deg -> angle_deg_v2: vfloat(min: 0, max: 360, step: 0.05)
      + heal_radius: vfloat(min: 0, max: 25, step: 0.25) = 0.0
      ~ imported_player -> updated_imported_player: Player@6
    }
  }

  version 3 {
    type EmptyStruct {}

    type SensorFrame {
      readings: [i32](delta) = []
      sample_ids: [u64](delta, 8) = [0, 0, 0, 0, 0, 0, 0, 0]
      calibration: vfloat(min: -10, max: 10, step: 0.01) = 0.0
    }

    // A second, independent union coexisting with Payload — exercises the
    // codegen paths that iterate "all unions in the schema" rather than
    // assuming there's exactly one.
    type PingPayload {}

    type PongPayload {
      latency_ms: u32 = 0
    }

    union ControlSignal {
      Ping: PingPayload,
      Pong: PongPayload,
    }

    // First step of a generic type-parameter-evolution chain (see v4/v5
    // below): a single-parameter template introduced fresh at v3.
    type Mono<A> {
      value: A
    }

    diff {
      + basic_map: map<string, string> = {}
      + fixed_map_empty: map<i32, f32>(0) = {}
      + fixed_map_populated: map<string, i64>(4) = {"ok": -1, "not_ok": 1, "bad": 0, "bad2": 0}
      + nested_map: map<string, [map<i32, bool>]> = {}
      + void_container: EmptyStruct

      // Struct-typed diff Add — same free `Default::default()` pass as
      // `control` below, just for a monomorphized generic instantiation.
      // First link of the type-parameter-evolution chain below (v4/v5) —
      // each version pins its own field rather than retyping this one,
      // since (like any struct field in this schema) retyping across an
      // incompatible shape isn't supported, generic or not.
      + generic_mono_v3: Mono<string>

      ~ fixed_arr_populated -> array_to_map: map<i32, u8>
      ~ tuple_array -> flattened_tuple_array: [(f64, i64, string)]

      + sensor_log: [SensorFrame] = []
      + delta_value_map: map<string, [i64](delta)>(2) = {"entry": [], "entry2": []}

      // Bare union field added via diff — relies on the Union auto-default
      // carve-out (Default::default() -> Unknown variant), same free pass
      // non-primitive structs already get.
      + control: ControlSignal

      // Map with a union value type — generic Map codegen dispatches into
      // the same per-union read/write/size_hint functions as any other field.
      + control_map: map<string, Payload> = {}

      // Optional lazy map payload — callers that don't need to inspect it skip for free
      + lazy_sensor_dump: lazy map<string, [i32](delta)>?

      + vfloat_map: map<string, vfloat(min: 0, max: 1, step: 0.01)> = {}
    }
  }

  version 4 {
    bitset SystemPrivileges {
      Read,
      Write,
      Execute,
      Admin,
    }

    bitset HardwareFlags {
      IsCpuBound,
      IsGpuBound,
      HasVulkan,
    }

    type DisconnectPayload {
      reason_code: u16 = 0
    }

    type EmptyStruct {}

    union ControlSignal extends ControlSignal@3 {
      + Disconnect: DisconnectPayload
    }

    // Second step of the type-parameter-evolution chain — a *different*
    // generic name (`Duo`) extends `Mono`, passing its single param `A`
    // through unchanged and adding a brand-new param `B` of its own.
    type Duo<A, B> extends Mono<A>@3 {
      + secondary: B?
    }

    diff {
      + opt_u8: u8?
      + opt_i16: i16?
      + opt_u32: u32?
      + opt_i64: i64?
      + opt_f32: f32?
      + opt_f64: f64?
      + opt_bool: bool?
      + opt_fixed_str: string(4)?
      + opt_bitset: SystemPrivileges?

      ~ newly_added_optional: u64

      + privileges: SystemPrivileges = 0
      + hw_flags: HardwareFlags = HardwareFlags(IsCpuBound: true, HasVulkan: true)

      + opt_delta_arr: [i32](delta)?

      // Second link of the chain — a fresh field pinned to `Duo`, the
      // cross-name extension of `Mono` that adds its own parameter `B`.
      + generic_duo_v4: Duo<string, i32>

      // Re-resolve to ControlSignal@4 (now Disconnect-aware) — same Cast
      // exercise as `~ action: Payload` above, this time on the second union.
      ~ control: ControlSignal
      + control_log: [ControlSignal] = []

      // Lazy optional union field added via diff — must be Optional, same
      // rule as any other lazy diff addition (LazyDiffFieldMustBeOptional).
      + lazy_pending_signal: lazy ControlSignal?

      // Lazy sensor log upgrade — v4 makes it non-optional now that all peers support v2+
      // Still lazy: most consumers only care about count, not contents
      ~ lazy_sensor_dump: lazy map<string, [i32](delta)>

      + opt_vfloat: vfloat(min: 0, max: 1, step: 0.001)?
    }
  }

  version 5 {
    bitset SystemPrivileges extends SystemPrivileges@4 {
      + NetworkAccess
      - Admin
      + Root
    }

    type DeepComplexWrapper {
      matrix: [[(map<string, i32?>, string(8)?)](4)]
      frame_deltas: [i64](delta) = []
      scale: vfloat(min: 0.1, max: 10, step: 0.01) = 1.0
    }

    type DespawnPayload {
      entity_id: u32 = 0
    }

    // Extends from the latest existing Payload *definition* (@2) — v3/v4
    // never redefined Payload, only referenced it, so @2 is still correct.
    union Payload extends Payload@2 {
      + Despawn: DespawnPayload
    }

    // Final step of the type-parameter-evolution chain — back to a
    // single-param `Mono`, dropping `Duo`'s `B` via `_`. The dropped param's
    // only user (`secondary`) must be cleaned up in this same diff, below.
    type Mono<A> extends Duo<A, _>@4 {
      - secondary
    }

    diff {
      ~ privileges -> system_perms: SystemPrivileges
      ~ hw_flags -> legacy_hw_flags: u32

      + ultimate_boss_structure: DeepComplexWrapper

      // Final link of the chain — a fresh field pinned to this version's
      // `Mono`, which dropped `Duo`'s `B` via `_` above. Structurally
      // identical to v3's `Mono<string>` (both are just `{ value: string }`),
      // proving the wildcard-drop path produces a compatible shape again.
      + generic_mono_v5: Mono<string>

      ~ fixed_str_padded: string(2)
      ~ fixed_map_populated: map<string, i64>(2)

      ~ delta_fixed_u8: [u8](delta, 8)
      ~ delta_u32_seq -> u32_delta_seq: [u32](delta, 16)

      - void_container
      - flattened_tuple_array

      // Rename + retype an optional union field — Transform path, no default
      // logic involved at all (just name + type re-resolution).
      ~ pending_action -> deferred_action: Payload?

      // New field added fresh at v5 automatically picks up the most current
      // Payload (Move/Attack/Heal/Despawn) with no manual re-pin needed —
      // unlike `action`, which only sees new variants when explicitly diffed.
      + final_action: Payload

      // Lazy blob widened to include a tuple header — old lazy_blob bytes still valid on wire
      ~ lazy_blob -> lazy_annotated_blob: lazy [(u64, [u8])]

      // New in v5: bulk audit trail, expected to be large, almost never fully decoded
      + lazy_audit_log: lazy [string]?

      ~ normalized -> normalized_v5: vfloat(min: -1.0, max: 1.0, step: 0.0001)
    }
  }
}